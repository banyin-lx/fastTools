<Window x:Class="FastTools.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FastTools.App.Views"
        x:Name="RootWindow"
        Title="{Binding Localizer[Settings.Title], RelativeSource={RelativeSource Self}}"
        Width="1020"
        Height="700"
        Icon="pack://application:,,,/Assets/fastTools.png"
        MinWidth="900"
        MinHeight="620"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI"
        FontSize="14"
        ResizeMode="CanMinimize"
        ShowInTaskbar="True"
        WindowStartupLocation="Manual"
        WindowStyle="None">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="WindowCommandButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource SelectionBrush}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource ElevatedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowCommandButtonStyle"
               TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#B92C3E" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#8F2331" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="SettingsCardCompactStyle" TargetType="Border" BasedOn="{StaticResource SettingsCardStyle}">
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="SectionCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SectionHeadingStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="SectionSubheadingStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ModernMultilineTextBoxStyle"
               BasedOn="{StaticResource ModernTextBoxStyle}"
               TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               BasedOn="{StaticResource ChromeButtonStyle}"
               TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="PrimaryButtonStyle"
               BasedOn="{StaticResource ChromeButtonStyle}"
               TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="#0A1520" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Opacity" Value="0.85" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentStrongBrush}" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HotKeyCaptureButtonStyle"
               BasedOn="{StaticResource SecondaryButtonStyle}"
               TargetType="Button">
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource ElevatedBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavigationListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="NavigationListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Padding="10,8"
                                Background="Transparent"
                                CornerRadius="12">
                            <Grid>
                                <Border x:Name="SelectionIndicator"
                                        Width="3"
                                        Height="18"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="-6,0,0,0"
                                        Background="{DynamicResource AccentBrush}"
                                        CornerRadius="2"
                                        Visibility="Collapsed" />
                                <ContentPresenter />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource ElevatedBrush}" />
                            </MultiTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource SelectionBrush}" />
                                <Setter TargetName="SelectionIndicator"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type local:PluginSelectSettingItem}">
            <StackPanel Margin="0,0,0,14">
                <TextBlock Style="{StaticResource SectionCaptionStyle}"
                           Text="{Binding Label}" />
                <TextBlock Margin="0,0,0,8"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding Description}"
                           TextWrapping="Wrap"
                           Visibility="{Binding DescriptionVisibility}" />
                <ComboBox ItemsSource="{Binding Options}"
                          SelectedItem="{Binding SelectedOption}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:PluginDirectoryListSettingItem}">
            <StackPanel Margin="0,0,0,14">
                <TextBlock Style="{StaticResource SectionCaptionStyle}"
                           Text="{Binding Label}" />
                <TextBlock Margin="0,0,0,8"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding Description}"
                           TextWrapping="Wrap"
                           Visibility="{Binding DescriptionVisibility}" />
                <ItemsControl ItemsSource="{Binding Directories}"
                              Margin="0,0,0,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Background="{DynamicResource ChromeBrush}"
                                        CornerRadius="10"
                                        Padding="10,6">
                                    <TextBlock Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="{Binding}"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                                <Button Grid.Column="1"
                                        Margin="6,0,0,0"
                                        Padding="8,4"
                                        Click="RemovePluginDirectory_Click"
                                        Content="&#xE74D;"
                                        FontFamily="Segoe Fluent Icons"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Click="AddPluginDirectory_Click"
                        Content="添加目录"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Tag="{Binding}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:PluginUnknownSettingItem}">
            <TextBlock Margin="0,0,0,12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="{Binding Label}" />
        </DataTemplate>

        <Style x:Key="PluginToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track"
                                Background="#3E627D"
                                BorderBrush="#3E627D"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Ellipse x:Name="Thumb"
                                     Width="20"
                                     Height="20"
                                     Margin="2,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Fill="White" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#6CD2B2" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#6CD2B2" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0" />
                                <Setter TargetName="Thumb" Property="Fill" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1.5"
                                CornerRadius="10">
                            <Ellipse x:Name="Thumb"
                                     Width="14"
                                     Height="14"
                                     Margin="2,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#6CD2B2" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#6CD2B2" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0" />
                                <Setter TargetName="Thumb" Property="Fill" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="14"
            Background="{DynamicResource AppBackgroundBrush}"
            CornerRadius="30"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26"
                              Direction="270"
                              Opacity="0.28"
                              ShadowDepth="12"
                              Color="#050C14" />
        </Border.Effect>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="3"
                    Padding="10,6,8,10"
                    Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="42"
                                Height="42"
                                Background="{DynamicResource ChromeBrush}"
                                CornerRadius="14">
                            <Image Width="22"
                                   Height="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Source="pack://application:,,,/Assets/fastTools.png" />
                        </Border>
                        <StackPanel Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="FastTools" />
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="{Binding Localizer[Settings.Title], RelativeSource={RelativeSource AncestorType=Window}}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Click="MinimizeButton_Click"
                                Style="{StaticResource WindowCommandButtonStyle}">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       FontSize="12"
                                       Text="&#xE921;" />
                        </Button>
                        <Button Click="CloseWindowButton_Click"
                                Style="{StaticResource CloseWindowCommandButtonStyle}">
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       FontSize="12"
                                       Text="&#xE8BB;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Padding="22"
                    Background="{DynamicResource ChromeBrush}"
                    CornerRadius="28">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="{Binding Localizer[Settings.Header.Title], RelativeSource={RelativeSource AncestorType=Window}}" />
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             Margin="0,24,0,0"
                             ItemContainerStyle="{StaticResource NavigationListItemStyle}"
                             ItemsSource="{Binding Sections}"
                             SelectedItem="{Binding SelectedSection}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource NavigationListStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="28"
                                            Height="28"
                                            Background="{DynamicResource ElevatedBrush}"
                                            CornerRadius="8">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   Text="{Binding Glyph}" />
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="{Binding Title}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2"
                            Background="Transparent" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="2"
                    Padding="26"
                    Background="{DynamicResource ChromeBrush}"
                    CornerRadius="28">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Visibility="{Binding SelectedSectionHeaderVisibility}">
                        <TextBlock Style="{StaticResource SectionHeadingStyle}"
                                   Text="{Binding SelectedSectionTitle}" />
                    </StackPanel>

                    <ScrollViewer x:Name="ContentScrollViewer"
                                  Grid.Row="1"
                                  Margin="0,22,0,0"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <StackPanel Visibility="{Binding GeneralSectionVisibility}">
                                <Border Style="{StaticResource SettingsCardCompactStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="260" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="{Binding Localizer[Settings.Theme], RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <ComboBox Grid.Column="1"
                                                  DisplayMemberPath="Label"
                                                  ItemsSource="{Binding ThemeOptions}"
                                                  SelectedValue="{Binding SelectedTheme}"
                                                  SelectedValuePath="Value" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsCardCompactStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="260" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="{Binding Localizer[Settings.Language], RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <ComboBox Grid.Column="1"
                                                  DisplayMemberPath="Label"
                                                  ItemsSource="{Binding LanguageOptions}"
                                                  SelectedValue="{Binding SelectedLanguage}"
                                                  SelectedValuePath="Value" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsCardCompactStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Text="{Binding Localizer[Settings.HideShortcutResults], RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="{Binding Localizer[Settings.HideShortcutResults.Desc], RelativeSource={RelativeSource AncestorType=Window}}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      Margin="14,0,0,0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding HideShortcutResults}"
                                                      Style="{StaticResource PluginToggleButtonStyle}" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsCardCompactStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Text="{Binding Localizer[Settings.AlwaysOnTop], RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="{Binding Localizer[Settings.AlwaysOnTop.Desc], RelativeSource={RelativeSource AncestorType=Window}}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      Margin="14,0,0,0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding AlwaysOnTop}"
                                                      Style="{StaticResource PluginToggleButtonStyle}" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsCardCompactStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="260" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="{Binding Localizer[Settings.WindowPosition.Title], RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <ComboBox Grid.Column="1"
                                                  DisplayMemberPath="Label"
                                                  ItemsSource="{Binding SearchWindowPositionOptions}"
                                                  SelectedValue="{Binding SelectedWindowPositionMode}"
                                                  SelectedValuePath="Value" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsCardCompactStyle}">
                                    <Expander IsExpanded="{Binding IsPositionExpanded}">
                                        <Expander.Header>
                                            <TextBlock Text="{Binding Localizer[Settings.SearchBarPosition.Title], RelativeSource={RelativeSource AncestorType=Window}}"
                                                       FontWeight="SemiBold" />
                                        </Expander.Header>
                                        <StackPanel Margin="0,12,0,0">
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="260" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding Localizer[Settings.SearchBarPosition.Horizontal], RelativeSource={RelativeSource AncestorType=Window}}" />
                                                <ComboBox Grid.Column="1"
                                                          DisplayMemberPath="Label"
                                                          ItemsSource="{Binding SearchBarHorizontalOptions}"
                                                          SelectedValue="{Binding SelectedHorizontalPosition}"
                                                          SelectedValuePath="Value" />
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="260" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding Localizer[Settings.SearchBarPosition.Vertical], RelativeSource={RelativeSource AncestorType=Window}}" />
                                                <ComboBox Grid.Column="1"
                                                          DisplayMemberPath="Label"
                                                          ItemsSource="{Binding SearchBarVerticalOptions}"
                                                          SelectedValue="{Binding SelectedVerticalPosition}"
                                                          SelectedValuePath="Value" />
                                            </Grid>
                                        </StackPanel>
                                    </Expander>
                                </Border>
                                <Border Style="{StaticResource SettingsCardCompactStyle}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding Localizer[Settings.SearchDebounceEnabled], RelativeSource={RelativeSource AncestorType=Window}}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding Localizer[Settings.SearchDebounceEnabled.Desc], RelativeSource={RelativeSource AncestorType=Window}}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1"
                                                          Margin="14,0,0,0"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding SearchDebounceEnabled}"
                                                          Style="{StaticResource PluginToggleButtonStyle}" />
                                        </Grid>
                                        <Border Margin="0,14,0,0"
                                                Padding="14"
                                                Background="{DynamicResource SurfaceAltBrush}"
                                                BorderBrush="{DynamicResource DividerBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Visibility="{Binding SearchDebounceSettingsVisibility}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="160" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               Text="{Binding Localizer[Settings.SearchDebounceMilliseconds], RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Text="{Binding Localizer[Settings.SearchDebounceMilliseconds.Desc], RelativeSource={RelativeSource AncestorType=Window}}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBox Grid.Column="1"
                                                         Margin="14,0,0,0"
                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                         VerticalAlignment="Center"
                                                         HorizontalContentAlignment="Center"
                                                         PreviewTextInput="SearchDebounceMillisecondsTextBox_PreviewTextInput"
                                                         DataObject.Pasting="SearchDebounceMillisecondsTextBox_Pasting"
                                                         Text="{Binding SearchDebounceMillisecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SettingsCardCompactStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Text="{Binding Localizer[Settings.LoggingEnabled], RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="{Binding Localizer[Settings.LoggingEnabled.Desc], RelativeSource={RelativeSource AncestorType=Window}}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      Margin="14,0,0,0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding LoggingEnabled}"
                                                      Style="{StaticResource PluginToggleButtonStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel Visibility="{Binding HotKeysSectionVisibility}">
                                <Border Style="{StaticResource SettingsCardCompactStyle}">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="{Binding Localizer[Settings.SearchWakeHotKey], RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <Button x:Name="HotKeyCaptureButton"
                                                Grid.Column="1"
                                                Click="HotKeyButton_Click"
                                                Content="{Binding HotKeyText}"
                                                PreviewKeyDown="HotKeyCaptureButton_PreviewKeyDown"
                                                Style="{StaticResource HotKeyCaptureButtonStyle}" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsCardCompactStyle}">
                                    <Expander IsExpanded="{Binding IsResultActivationExpanded}">
                                        <Expander.Header>
                                            <TextBlock Text="{Binding Localizer[Settings.ResultActivation.Title], RelativeSource={RelativeSource AncestorType=Window}}"
                                                       FontWeight="SemiBold" />
                                        </Expander.Header>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock Margin="0,0,0,12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="{Binding Localizer[Settings.ResultActivation.Desc], RelativeSource={RelativeSource AncestorType=Window}}"
                                                       TextWrapping="Wrap" />
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="260" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding Localizer[Settings.ResultActivation.Mouse], RelativeSource={RelativeSource AncestorType=Window}}" />
                                                <ComboBox Grid.Column="1"
                                                          DisplayMemberPath="Label"
                                                          ItemsSource="{Binding ResultMouseActivationOptions}"
                                                          SelectedValue="{Binding SelectedResultMouseActivationMode}"
                                                          SelectedValuePath="Value" />
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding Localizer[Settings.ResultActivation.Keyboard], RelativeSource={RelativeSource AncestorType=Window}}" />
                                                <Button x:Name="ResultKeyboardActivationButton"
                                                        Grid.Column="1"
                                                        Click="ResultKeyboardActivationButton_Click"
                                                        Content="{Binding ResultKeyboardActivationGestureText}"
                                                        PreviewKeyDown="ResultKeyboardActivationButton_PreviewKeyDown"
                                                        Style="{StaticResource HotKeyCaptureButtonStyle}" />
                                            </Grid>
                                        </StackPanel>
                                    </Expander>
                                </Border>
                            </StackPanel>

                            <StackPanel Visibility="{Binding CommandsSectionVisibility}">
                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <StackPanel>
                                        <StackPanel Margin="0,0,0,16"
                                                    HorizontalAlignment="Right"
                                                    Orientation="Horizontal">
                                            <Button Margin="0,0,10,0"
                                                    Click="AddCommandButton_Click"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="{Binding Localizer[Settings.Add], RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <Button Click="RemoveCommandButton_Click"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="{Binding Localizer[Settings.Remove], RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </StackPanel>

                                        <DataGrid x:Name="CustomCommandsGrid"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  HeadersVisibility="Column"
                                                  ItemsSource="{Binding CustomCommands}"
                                                  MinHeight="360"
                                                  SelectedItem="{Binding SelectedCustomCommand}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn x:Name="CommandNameColumn"
                                                                    Width="1.2*"
                                                                    Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                <DataGridTextColumn x:Name="CommandAliasColumn"
                                                                    Width="1*"
                                                                    Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}" />
                                                <DataGridTextColumn x:Name="CommandPathColumn"
                                                                    Width="1.2*"
                                                                    Binding="{Binding Command, UpdateSourceTrigger=PropertyChanged}" />
                                                <DataGridTextColumn x:Name="CommandArgsColumn"
                                                                    Width="1.2*"
                                                                    Binding="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" />
                                                <DataGridTemplateColumn x:Name="CommandConfirmColumn"
                                                                                        Width="0.8*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <ToggleButton HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          IsChecked="{Binding RequiresConfirmation, UpdateSourceTrigger=PropertyChanged}"
                                                                          Style="{StaticResource DataGridToggleButtonStyle}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Visibility="{Binding PrioritySectionVisibility}">
                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,16"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding Localizer[Settings.Priority.Help], RelativeSource={RelativeSource AncestorType=Window}}" />

                                        <ListBox x:Name="PriorityList"
                                                 AllowDrop="True"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 DragOver="PriorityList_DragOver"
                                                 Drop="PriorityList_Drop"
                                                 GiveFeedback="PriorityList_GiveFeedback"
                                                 ItemsSource="{Binding SearchGroupPriorities}"
                                                 MinHeight="280"
                                                 PreviewMouseLeftButtonDown="PriorityList_PreviewMouseLeftButtonDown"
                                                 PreviewMouseMove="PriorityList_PreviewMouseMove"
                                                 SelectedItem="{Binding SelectedSearchGroupPriority}"
                                                 SelectionMode="Single">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="AllowDrop" Value="True" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="0,0,0,8" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Cursor" Value="SizeAll" />
                                                    <EventSetter Event="DragEnter" Handler="PriorityItem_DragEnter" />
                                                    <EventSetter Event="DragLeave" Handler="PriorityItem_DragLeave" />
                                                    <EventSetter Event="Drop" Handler="PriorityList_Drop" />
                                                    <EventSetter Event="DragOver" Handler="PriorityList_DragOver" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Grid>
                                                                    <Border x:Name="DropIndicator"
                                                                            Height="3"
                                                                            Margin="4,-6,4,0"
                                                                            VerticalAlignment="Top"
                                                                            Background="{DynamicResource AccentBrush}"
                                                                            CornerRadius="2"
                                                                            Visibility="Collapsed" />
                                                                    <Border x:Name="Root"
                                                                            Padding="14,12"
                                                                            Background="{DynamicResource ElevatedBrush}"
                                                                            BorderBrush="Transparent"
                                                                            BorderThickness="1"
                                                                            CornerRadius="14">
                                                                        <ContentPresenter />
                                                                    </Border>
                                                                </Grid>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Root"
                                                                                Property="BorderBrush"
                                                                                Value="{DynamicResource AccentBrush}" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="Root"
                                                                                Property="Background"
                                                                                Value="{DynamicResource SelectionBrush}" />
                                                                        <Setter TargetName="Root"
                                                                                Property="BorderBrush"
                                                                                Value="{DynamicResource AccentBrush}" />
                                                                    </Trigger>
                                                                    <Trigger Property="Tag" Value="DropTarget">
                                                                        <Setter TargetName="DropIndicator"
                                                                                Property="Visibility"
                                                                                Value="Visible" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel LastChildFill="True">
                                                        <TextBlock DockPanel.Dock="Left"
                                                                   Margin="0,0,14,0"
                                                                   VerticalAlignment="Center"
                                                                   FontFamily="Segoe Fluent Icons"
                                                                   FontSize="16"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Text="&#xE700;" />
                                                        <ToggleButton DockPanel.Dock="Right"
                                                                              Margin="14,0,0,0"
                                                                              VerticalAlignment="Center"
                                                                              IsChecked="{Binding IsEnabled}"
                                                                              Style="{StaticResource PluginToggleButtonStyle}" />
                                                        <TextBlock VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Text="{Binding DisplayGroup}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                            <Setter Property="Opacity" Value="0.4" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Visibility="{Binding PluginsSectionVisibility}">
                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <ItemsControl ItemsSource="{Binding PluginStates}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10"
                                                        Padding="14"
                                                        Background="{DynamicResource ElevatedBrush}"
                                                        CornerRadius="14">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="88" />
                                                        </Grid.ColumnDefinitions>
                                                        <Expander Grid.Column="0"
                                                                  IsExpanded="{Binding IsExpanded}">
                                                            <Expander.Header>
                                                                <StackPanel Margin="0,0,10,0">
                                                                    <TextBlock VerticalAlignment="Center"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                                               Text="{Binding DisplayName}" />
                                                                    <TextBlock Margin="0,4,0,0"
                                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                                               Text="{Binding Description}"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Expander.Header>
                                                            <StackPanel Margin="0,12,0,0">
                                                                <ItemsControl ItemsSource="{Binding Settings}"
                                                                              Visibility="{Binding HasSettingsVisibility}" />
                                                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           Text="该插件暂无可配置项。"
                                                                           Visibility="{Binding EmptySettingsVisibility}" />
                                                            </StackPanel>
                                                        </Expander>
                                                        <Border Grid.Column="1"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Background="Transparent">
                                                            <ToggleButton Margin="10,2,0,0"
                                                                          VerticalAlignment="Center"
                                                                          IsChecked="{Binding IsEnabled}"
                                                                          Style="{StaticResource PluginToggleButtonStyle}" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>

                            <Grid Visibility="{Binding LogsSectionVisibility}"
                                  Height="{Binding ViewportHeight, ElementName=ContentScrollViewer}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource SettingsCardCompactStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Localizer[Settings.Logs.MinLevel], RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <ComboBox Width="160"
                                                      Margin="12,0"
                                                      DisplayMemberPath="Label"
                                                      ItemsSource="{Binding LogLevelOptions}"
                                                      SelectedValue="{Binding SelectedLogLevel}"
                                                      SelectedValuePath="Value" />
                                            <Button Margin="0,0,8,0"
                                                    Click="CopyAllLogs_Click"
                                                    Content="{Binding Localizer[Settings.Logs.CopyAll], RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                            <Button Click="ClearLogs_Click"
                                                    Content="{Binding Localizer[Settings.Logs.Clear], RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1"
                                        Style="{StaticResource SettingsCardStyle}"
                                        RequestBringIntoView="LogBox_RequestBringIntoView">
                                    <Border Padding="6"
                                            Background="{DynamicResource ChromeBrush}"
                                            CornerRadius="10">
                                        <RichTextBox x:Name="LogTextBox"
                                                     IsReadOnly="True"
                                                     IsReadOnlyCaretVisible="True"
                                                     IsDocumentEnabled="True"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Padding="6"
                                                     FontFamily="Consolas, Cascadia Mono, Courier New"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     HorizontalScrollBarVisibility="Disabled"
                                                     VerticalScrollBarVisibility="Auto"
                                                     AcceptsReturn="False"
                                                     UndoLimit="0">
                                            <RichTextBox.Resources>
                                                <Style TargetType="Paragraph">
                                                    <Setter Property="Margin" Value="0,1,0,1" />
                                                </Style>
                                            </RichTextBox.Resources>
                                            <FlowDocument PagePadding="0"
                                                          ColumnWidth="9999"
                                                          ColumnGap="0"
                                                          IsColumnWidthFlexible="False" />
                                        </RichTextBox>
                                    </Border>
                                </Border>
                            </Grid>

                            <StackPanel Visibility="{Binding AboutSectionVisibility}">
                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <StackPanel HorizontalAlignment="Center"
                                                Margin="0,12,0,12">
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="{Binding AppDisplayName}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding AppVersion, StringFormat='v{0}'}" />
                                        <TextBlock Margin="0,18,0,0"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding Localizer[Settings.About.Tagline], RelativeSource={RelativeSource AncestorType=Window}}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center" />
                                        <Button Margin="0,18,0,0"
                                                HorizontalAlignment="Center"
                                                Click="OpenGitHub_Click"
                                                Style="{StaticResource SecondaryButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe Fluent Icons"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center"
                                                           Text="&#xE71B;" />
                                                <TextBlock VerticalAlignment="Center"
                                                           Text="{Binding AppGitHubUrl}" />
                                            </StackPanel>
                                        </Button>
                                        <TextBlock Margin="0,16,0,0"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding AppCopyright}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button Margin="0,0,12,0"
                                Click="CancelButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="{Binding Localizer[Settings.Cancel], RelativeSource={RelativeSource AncestorType=Window}}" />
                        <Button Click="SaveButton_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="{Binding Localizer[Settings.Save], RelativeSource={RelativeSource AncestorType=Window}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
