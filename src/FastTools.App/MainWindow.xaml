<Window x:Class="FastTools.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FastTools"
        Width="740"
        Icon="pack://application:,,,/Assets/fastTools.png"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI"
        FontSize="14"
        MaxHeight="520"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        WindowStyle="None">
    <Border x:Name="ChromeBorder"
            Margin="24"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            MouseLeftButtonDown="ChromeBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="14,10,14,10"
                    Background="Transparent"
                    BorderThickness="0">
                <Grid MinHeight="34">
                    <TextBox x:Name="SearchBox"
                             MinHeight="34"
                             Margin="0"
                             PreviewKeyDown="SearchBox_PreviewKeyDown"
                             Style="{StaticResource SearchTextBoxStyle}"
                             TextChanged="SearchBox_TextChanged" />
                    <TextBlock x:Name="SearchPlaceholder"
                               Margin="2,0,0,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               IsHitTestVisible="False"
                               Opacity="0.45"
                               Text="{Binding Localizer[Main.SearchPlaceholder]}" />
                </Grid>
            </Border>

            <Border x:Name="ResultsPanel"
                    Grid.Row="1"
                    Padding="0,8,0,2"
                    Background="Transparent"
                    BorderThickness="0"
                    MaxHeight="360"
                    Opacity="0"
                    Visibility="{Binding ResultsVisibility}">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ResultsPanelTranslate" Y="10" />
                </Border.RenderTransform>
                <Grid>
                    <Border Height="1"
                            Margin="14,0,14,8"
                            VerticalAlignment="Top"
                            Background="{DynamicResource BorderBrush}" />

                    <ListBox x:Name="ResultsList"
                             Margin="0,8,0,0"
                             Padding="0,0,0,0"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding ResultsView}"
                             PreviewMouseDoubleClick="ResultsList_PreviewMouseDoubleClick"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.CanContentScroll="False"
                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                             SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                             Visibility="{Binding ResultsListVisibility}">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="14,8,14,8"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   Text="{Binding Name}" />
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="12,4" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Root"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="14">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Root"
                                                            Property="Background"
                                                            Value="{DynamicResource SelectionBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Root"
                                                            Property="Background"
                                                            Value="{DynamicResource ElevatedBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="ResultIconHost"
                                            Width="44"
                                            Height="44"
                                            Margin="0,0,14,0"
                                            Background="Transparent"
                                            CornerRadius="14">
                                        <Grid>
                                            <Image x:Name="ResultIcon"
                                                   Width="20"
                                                   Height="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Source="{Binding Icon}" />
                                            <TextBlock x:Name="ResultGlyph"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Segoe Fluent Icons"
                                                       FontSize="18"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       Visibility="Collapsed"
                                                       Text="{Binding Glyph}" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="{Binding Title}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding Subtitle}" />
                                    </StackPanel>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                        <Setter TargetName="ResultIconHost"
                                                Property="Background"
                                                Value="{DynamicResource ElevatedBrush}" />
                                        <Setter TargetName="ResultGlyph"
                                                Property="Visibility"
                                                Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
